marks=[]
for i in range(5):
    m = int(input("Enter marks:  "))
    marks.append(m)

def calculate_average(marks):
    total = 0
    for m in marks:
        total += m
    avg = total / len(marks)
    return avg

avg = calculate_average(marks)
print("Average:", avg)


if avg >= 80:
    print("Grade: A")
elif avg >= 60:
    print("Grade: B")
elif avg >= 50:
    print("Grade: C")
else:
    print("Grade: Fail")
